# DigiKey Product Information API credentials.
# Create an app at https://developer.digikey.com/ (Production or Sandbox) and
# copy this file to ".env" in your KiCad project folder.

DIGIKEY_CLIENT_ID=your-client-id
DIGIKEY_CLIENT_SECRET=your-client-secret

# Use the sandbox host instead of production (optional).
# DIGIKEY_SANDBOX=1

# Locale (optional; these are the defaults).
# DIGIKEY_LOCALE_SITE=US
# DIGIKEY_LOCALE_LANGUAGE=en
# DIGIKEY_LOCALE_CURRENCY=USD
